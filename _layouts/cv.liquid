---
layout: default
title: "Curriculum Vitae"
cv_pdf: "KeLin_CV_July2024.pdf"  # This corresponds to page.cv_pdf from cv.md
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          href="{{ '/assets/pdf/' | append: page.cv_pdf | relative_url }}"
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
          ><i class="fa-solid fa-file-pdf"></i
        ></a>
      {% endif %}
    </h1>
  </header>

  <article>
    {% if page.cv_pdf %}
      <div class="pdf-embed">
        <iframe
          src="{{ '/assets/pdf/' | append: page.cv_pdf | relative_url }}"
          width="100%"
          height="1000px"
          style="border: none;"
        ></iframe>
      </div>
    {% else %}
      <p>No CV PDF found.</p>
    {% endif %}
  </article>
</div>

{% if paginator.total_pages > 1 %}
  {% if paginator.previous_page %}
    <a href="{{ paginator.previous_page_path }}">Previous</a>
  {% endif %}
  
  {% for page in (1..paginator.total_pages) %}
    {% if page == paginator.page %}
      <span>{{ page }}</span>
    {% else %}
      <a href="{{ paginator.page_path }}">{{ page }}</a>
    {% endif %}
  {% endfor %}

  {% if paginator.next_page %}
    <a href="{{ paginator.next_page_path }}">Next</a>
  {% endif %}
{% endif %}
